  class "App::InputState" as AppInputState {
    + double mouseX = 0
    + double mouseY = 0
    + bool leftDown = false
    + bool middleDown = false
    + bool previousLeftDown = false
    + bool previousMiddleDown = false
    + float scrollDelta = 0
  }

  class "sc::glfw::framebufferSize<T,Method>" as GLFWFramebufferTemplate
  class "sc::glfw::cursorPos<T,Method>" as GLFWCursorTemplate
  class "sc::glfw::mouseButton<T,Method>" as GLFWMouseTemplate
  class "sc::glfw::scroll<T,Method>" as GLFWScrollTemplate

  App *-- AppInputState
}

