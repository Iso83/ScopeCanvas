    - ScopeCanvas::Render::Scene::SceneBuilder m_sceneBuilder
    - ScopeCanvas::Routing::EdgeRouter m_router
    - vector<Core::CanvasNodeId> m_nodeIds
    - vector<Core::CanvasNodeId> m_selectedNodes
    - Core::CanvasNodeId m_dragNode
    - glm::vec2 m_dragOffset
    - glm::vec2 m_dragAnchorStartPosition
    - vector<Core::CanvasNodeId> m_dragSelection
    - vector<glm::vec2> m_dragSelectionStartPositions
    - Core::CanvasConnectorId m_activeConnector
    - bool m_reconnectingEdge
    - bool m_reconnectingFromStart
    - Core::CanvasConnectorId m_reconnectFixedConnector
    - Core::CanvasConnectorId m_reconnectOriginalFrom
    - Core::CanvasConnectorId m_reconnectOriginalTo
    - bool m_selectionRectActive
    - glm::vec2 m_selectionRectStart
    - glm::vec2 m_selectionRectEnd
    - glm::vec2 m_previewEdgeEnd
