    + App()
    + ~App()
    + bool init()
    + void run()
    + void onFramebufferSizeChanged(int, int)
    + void onCursorPos(double, double)
    + void onMouseButton(int, int, int)
    + void onScroll(double, double)
    - bool initWindow()
    - bool initGL()
    - void initializeDocument()
    - void shutdown()
    - void processInput(float)
    - void setupCallbacks()
    - glm::vec2 screenToWorld(double, double) const
